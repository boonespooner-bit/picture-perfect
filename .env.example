# Copy to .env for local development (never commit .env)
GEMINI_API_KEY=your-key-from-aistudio.google.com/apikey

# Google Photos import (optional — the app works without it)
# From console.cloud.google.com: enable "Google Photos Picker API",
# then create an OAuth 2.0 Web client (see README).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional overrides:
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# PORT=3000
# DATA_DIR=./data
